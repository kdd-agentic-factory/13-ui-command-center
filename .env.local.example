# InsForge cloud backend — KDD Agentic Factory project
# Copy to .env.local and fill in your project credentials.
# Find them in .insforge/project.json (api_key) and the InsForge console.
VITE_INSFORGE_URL=https://<appkey>.eu-central.insforge.app
VITE_INSFORGE_ANON_KEY=ik_<your-api-key>
VITE_BLUEPRINT_WEB_URL=https://<your-blueprint-web-url>
VITE_GOVERNANCE_URL=https://<gateway>/api/governance
VITE_ORCHESTRATOR_URL=https://<gateway>/api/orchestrator
VITE_SKILLS_URL=https://<gateway>/api/skills
VITE_WORKFLOWS_URL=https://<gateway>/api/workflows
VITE_EXPERIMENTS_URL=https://<gateway>/api/experiments
VITE_MCP_URL=https://<gateway>/api/mcp
VITE_TELEMETRY_URL=https://<gateway>/api/telemetry
VITE_TWIN_URL=https://<gateway>/api/twin
VITE_RAG_URL=https://<gateway>/api/rag
VITE_SECURITY_URL=https://<gateway>/api/security
VITE_PIPELINES_URL=https://<gateway>/api/pipelines
