# Production build env for the InsForge static deployment
# (https://kdd-agentic-factory.insforge.site).
#
# These are PUBLIC URLs only — no secrets. The static site has no nginx of its
# own, so it calls the Fly BFF (kdd-rjz-ui.fly.dev) cross-origin; that BFF
# injects the internal API key server-side and is CORS-allowed for this origin.
# api.ts reads these VITE_<SVC>_URL overrides; data paths append /api/v1/...
VITE_GOVERNANCE_URL=https://kdd-rjz-ui.fly.dev/api/governance
VITE_ORCHESTRATOR_URL=https://kdd-rjz-ui.fly.dev/api/orchestrator
VITE_SKILLS_URL=https://kdd-rjz-ui.fly.dev/api/skills
VITE_WORKFLOWS_URL=https://kdd-rjz-ui.fly.dev/api/workflows
VITE_EXPERIMENTS_URL=https://kdd-rjz-ui.fly.dev/api/experiments
VITE_MCP_URL=https://kdd-rjz-ui.fly.dev/api/mcp
